/**
 * In-memory sliding-window rate limiter.
 *
 * This is intentionally simple and has a real limitation: it only works within
 * a single server process, so it will under-count in a multi-instance/serverless
 * deployment. architecture.md specifies Redis for production rate limiting
 * (shared state across instances, survives restarts) — swap this out before
 * scaling past one instance. Kept as in-memory here so the project runs with
 * zero external services during local development.
 */

interface Bucket {
  hits: number[];
}

const buckets = new Map<string, Bucket>();

export function rateLimit(key: string, maxRequests: number, windowSeconds: number): { allowed: boolean; remaining: number } {
  const now = Date.now();
  const windowMs = windowSeconds * 1000;
  const bucket = buckets.get(key) ?? { hits: [] };

  bucket.hits = bucket.hits.filter((t) => now - t < windowMs);

  if (bucket.hits.length >= maxRequests) {
    buckets.set(key, bucket);
    return { allowed: false, remaining: 0 };
  }

  bucket.hits.push(now);
  buckets.set(key, bucket);
  return { allowed: true, remaining: maxRequests - bucket.hits.length };
}

/** Best-effort client identifier for rate limiting behind a proxy/CDN. */
export function clientKeyFromRequest(req: Request): string {
  const fwd = req.headers.get('x-forwarded-for');
  return fwd?.split(',')[0]?.trim() ?? 'unknown';
}
