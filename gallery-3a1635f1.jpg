import { notFound } from 'next/navigation';
import Link from 'next/link';
import { getProductBySlug, getRelatedProducts } from '@/db';

export const dynamic = 'force-dynamic';

export default async function ProductDetailPage({ params }: { params: { slug: string } }) {
  const product = getProductBySlug(params.slug);
  if (!product || product.status !== 'PUBLISHED') notFound();

  const related = getRelatedProducts(product.category_id, product.id, 3);

  return (
    <main className="section wrap" style={{ maxWidth: 820 }}>
      <Link href="/products" style={{ fontSize: '.85rem', color: 'var(--ink-soft)', textDecoration: 'none' }}>← All products</Link>
      <p className="eyebrow" style={{ marginTop: '1.2rem' }}>{product.category_title}</p>
      <h1 style={{ fontSize: 'clamp(2rem,3vw,2.8rem)', marginBottom: '1rem' }}>{product.title}</h1>
      <p style={{ fontSize: '1.05rem', color: 'var(--ink-soft)', marginBottom: '1.6rem' }}>{product.summary}</p>

      <div className="card" style={{ padding: '1.6rem', marginBottom: '1.6rem' }}>
        <h3 style={{ fontSize: '.95rem', marginBottom: '.5rem' }}>Primary application</h3>
        <p style={{ fontSize: '.9rem', color: 'var(--ink-soft)' }}>{product.application}</p>
      </div>

      <div className="card" style={{ padding: '1.6rem', marginBottom: '1.6rem' }}>
        <h3 style={{ fontSize: '.95rem', marginBottom: '.5rem' }}>Technical datasheet</h3>
        <p style={{ fontSize: '.88rem', color: 'var(--ink-faint)' }}>
          {product.datasheet_url ? <a href={product.datasheet_url}>Download datasheet</a> : 'Not yet uploaded — request one directly.'}
        </p>
      </div>

      <div style={{ display: 'flex', gap: '.8rem', flexWrap: 'wrap', marginBottom: '2.5rem' }}>
        <Link href={`/contact?product=${encodeURIComponent(product.title)}`} className="btn btn--primary">Add to Quote</Link>
        <Link href={`/contact?product=${encodeURIComponent(product.title)}`} className="btn btn--ghost">WhatsApp inquiry</Link>
      </div>

      {related.length > 0 && (
        <>
          <h3 style={{ fontSize: '1.1rem', marginBottom: '1rem' }}>Related products</h3>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px,1fr))', gap: '1rem' }}>
            {related.map((r) => (
              <Link key={r.id} href={`/products/${r.slug}`} className="card" style={{ padding: '1.1rem', textDecoration: 'none', display: 'block' }}>
                <h4 style={{ fontSize: '.95rem', color: 'var(--ink)' }}>{r.title}</h4>
              </Link>
            ))}
          </div>
        </>
      )}
    </main>
  );
}
